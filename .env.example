APP_HOST=127.0.0.1
APP_PORT=8099
APP_LOG_LEVEL=info
APP_TIMEZONE=Europe/Moscow

# Option 1: explicit cookies copied from Gemini / Google session.
GEMINI_SECURE_1PSID=
GEMINI_SECURE_1PSIDTS=

# Option 2: path to exported cookies JSON.
# Supports either:
# - {"__Secure-1PSID":"...", "__Secure-1PSIDTS":"..."}
# - browser extension export array with name/value/domain fields
GEMINI_COOKIE_JSON_PATH=

# Option 3: keep empty values above and let browser-cookie3 read
# local browser cookies from a logged-in profile automatically.
GEMINI_ALLOW_BROWSER_COOKIE_FALLBACK=true

GEMINI_PROXY=
GEMINI_VERIFY_SSL=true
GEMINI_TIMEOUT_SEC=300
GEMINI_AUTO_CLOSE=false
GEMINI_CLOSE_DELAY_SEC=300
GEMINI_AUTO_REFRESH=true
GEMINI_REFRESH_INTERVAL_SEC=540
GEMINI_WATCHDOG_TIMEOUT_SEC=30
GEMINI_VERBOSE=false

DOWNLOADS_DIR=downloads
CAPTURES_DIR=captures
AGENTS_DIR=data/agents
N8N_BASE_URL=https://your-n8n.example.com
N8N_API_KEY=
N8N_FETCH_WORKFLOW_ID=h9vyvsEgeLRw8SoybyRj4
N8N_REPORT_INGEST_URL=
GEMINI_WEB_PROFILE_DIR=profiles/gemini-runner
DEFAULT_IMAGE_SUBDIR=generated
NODE_COMMAND=node
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
